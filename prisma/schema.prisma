// ============================================
// OnChain SafeNS MVP — Phase-0 Prisma Schema
// SRS §6.2 Entity & Data Model 기준
// ============================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Phase-0 엔터티 (6종)
// ─────────────────────────────────────────────

/// 일반 유저 — 이메일 인증 기반
model User {
  userId                 String    @id @default(uuid()) @map("user_id")
  email                  String    @unique
  emailVerified          Boolean   @default(false) @map("email_verified")
  verificationCode       String?   @map("verification_code")
  verificationExpiresAt  DateTime? @map("verification_expires_at")
  falseReportCount       Int       @default(0) @map("false_report_count")
  reportRestrictionUntil DateTime? @map("report_restriction_until")
  createdAt              DateTime  @default(now()) @map("created_at")

  // Relations
  fraudReports  FraudReport[]
  safeNames     SafeName[]
  transferDemos TransferDemo[]

  @@map("users")
}

/// Safe-Name — 사람이 읽을 수 있는 이름 ↔ 지갑 주소 매핑
model SafeName {
  nameId        String   @id @default(uuid()) @map("name_id")
  humanName     String   @unique @map("human_name")
  chain         String
  walletAddress String   @map("wallet_address")
  ownerId       String   @map("owner_id")
  status        String   @default("active")
  registeredAt  DateTime @default(now()) @map("registered_at")

  // Relations
  owner         User           @relation(fields: [ownerId], references: [userId])
  transferDemos TransferDemo[]

  @@map("safe_names")
}

/// 사기 주소 DB — 운영자 승인 후 등록
model FraudAddress {
  fraudId         String   @id @default(uuid()) @map("fraud_id")
  chain           String
  address         String
  riskLevel       String   @map("risk_level")
  reportCount     Int      @default(0) @map("report_count")
  sourceType      String   @map("source_type")
  firstReportedAt DateTime @map("first_reported_at")
  status          String   @default("verified")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([address])
  @@map("fraud_addresses")
}

/// 사기 주소 신고 — 유저가 제출, 운영자가 심사
model FraudReport {
  reportId       String    @id @default(uuid()) @map("report_id")
  reporterId     String    @map("reporter_id")
  reportedAddress String   @map("reported_address")
  chain          String
  description    String
  evidenceUrl    String    @map("evidence_url")
  status         String    @default("submitted")
  reviewerNotes  String?   @map("reviewer_notes")
  reportedAt     DateTime  @default(now()) @map("reported_at")
  reviewedAt     DateTime? @map("reviewed_at")

  // Relations
  reporter User @relation(fields: [reporterId], references: [userId])

  @@map("fraud_reports")
}

/// 운영자 — Admin 관리 계정
model Operator {
  operatorId String   @id @default(uuid()) @map("operator_id")
  name       String
  email      String   @unique
  role       String   @default("admin")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("operators")
}

/// 데모 이체 — Phase-0 시뮬레이션 전용
model TransferDemo {
  transferId      String    @id @default(uuid()) @map("transfer_id")
  senderId        String    @map("sender_id")
  recipientName   String    @map("recipient_name")
  resolvedAddress String?   @map("resolved_address")
  chain           String?
  amount          Float
  fraudStatus     String    @map("fraud_status")
  fraudDetail     String?   @map("fraud_detail")
  transferStatus  String    @map("transfer_status")
  notifiedAt      DateTime? @map("notified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  sender    User      @relation(fields: [senderId], references: [userId])
  safeName  SafeName? @relation(fields: [recipientName], references: [humanName])

  @@map("transfer_demos")
}
